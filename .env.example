NODE_ENV=development

APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000

# Managed PostgreSQL provider connection.
# Use a dedicated development database. Do not point local development at production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Optional direct connection for Prisma migrations when the provider exposes pooler + direct URLs.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Optional shadow database for `pnpm db:migrate:dev` against managed PostgreSQL.
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/SHADOW_DATABASE?schema=public&sslmode=require"

JWT_ACCESS_SECRET=change-me-in-development
JWT_REFRESH_SECRET=change-me-in-development
