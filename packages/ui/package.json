{
  "name": "@soyre/ui",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "default": "./dist/styles/index.css"
    }
  },
  "sideEffects": [
    "./dist/styles/*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && rm -rf dist/styles && cp -R src/styles dist/styles",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No UI tests configured yet'"
  },
  "peerDependencies": {
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^1.22.0"
  }
}
