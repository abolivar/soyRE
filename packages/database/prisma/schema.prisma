model Organization {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                   @unique
  status                  OrganizationStatus       @default(ACTIVE)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  memberships             Membership[]
  auditLogs               AuditLog[]
  clients                 Client[]
  clientIdentityDocuments ClientIdentityDocument[]
  properties              Property[]
  realEstateAgents        RealEstateAgent[]
  businesses              Business[]
  businessParticipants    BusinessParticipant[]
  contractTypes           ContractType[]
  documents               Document[]
  mandates                Mandate[]
  listings                Listing[]
  showings                Showing[]
  offers                  Offer[]
  workflowStages          WorkflowStage[]
  payoutProfiles          PayoutProfile[]
  payoutMethods           PayoutMethod[]
  disbursements           Disbursement[]
  compensationApplications CompensationApplication[]

  @@map("organizations")
}

model User {
  id                             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                          String                   @unique
  firstName                      String                   @map("first_name")
  lastName                       String?                  @map("last_name")
  passwordHash                   String                   @map("password_hash")
  status                         UserStatus               @default(PENDING)
  emailVerifiedAt                DateTime?                @map("email_verified_at")
  lastLoginAt                    DateTime?                @map("last_login_at")
  createdAt                      DateTime                 @default(now()) @map("created_at")
  updatedAt                      DateTime                 @updatedAt @map("updated_at")
  memberships                    Membership[]
  auditLogs                      AuditLog[]               @relation("ActorAuditLogs")
  assignedClients                Client[]                 @relation("AssignedClients")
  assignedProperties             Property[]               @relation("AssignedProperties")
  createdClientIdentityDocuments ClientIdentityDocument[] @relation("CreatedClientIdentityDocuments")
  createdBusinesses              Business[]               @relation("CreatedBusinesses")
  updatedBusinesses              Business[]               @relation("UpdatedBusinesses")
  lockedBusinesses               Business[]               @relation("LockedBusinesses")
  businessParticipants           BusinessParticipant[]    @relation("BusinessParticipantUsers")
  createdBusinessContracts       BusinessContract[]       @relation("CreatedBusinessContracts")
  updatedBusinessContracts       BusinessContract[]       @relation("UpdatedBusinessContracts")
  createdPaymentPlans            PaymentPlan[]            @relation("CreatedPaymentPlans")
  updatedPaymentPlans            PaymentPlan[]            @relation("UpdatedPaymentPlans")
  createdCommissionPlans         CommissionPlan[]         @relation("CreatedCommissionPlans")
  updatedCommissionPlans         CommissionPlan[]         @relation("UpdatedCommissionPlans")
  createdCalculationSnapshots    CalculationSnapshot[]    @relation("CreatedCalculationSnapshots")
  assignedScheduledActions       ScheduledAction[]        @relation("AssignedScheduledActions")
  uploadedDocuments              Document[]               @relation("UploadedDocuments")
  reviewedDocuments              Document[]               @relation("ReviewedDocuments")
  assignedMandates               Mandate[]                @relation("AssignedMandates")
  assignedShowings               Showing[]                @relation("AssignedShowings")
  assignedOffers                 Offer[]                  @relation("AssignedOffers")
  createdPayoutProfiles          PayoutProfile[]          @relation("CreatedPayoutProfiles")
  updatedPayoutProfiles          PayoutProfile[]          @relation("UpdatedPayoutProfiles")
  createdPayoutMethods           PayoutMethod[]           @relation("CreatedPayoutMethods")
  updatedPayoutMethods           PayoutMethod[]           @relation("UpdatedPayoutMethods")
  createdDisbursements           Disbursement[]           @relation("CreatedDisbursements")
  updatedDisbursements           Disbursement[]           @relation("UpdatedDisbursements")
  approvedDisbursements          Disbursement[]           @relation("ApprovedDisbursements")
  appliedCompensations           CompensationApplication[] @relation("AppliedCompensations")
  reversedCompensations          CompensationApplication[] @relation("ReversedCompensations")
  payoutProfiles                 PayoutProfile[]          @relation("RecipientPayoutProfiles")

  @@map("users")
}

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           MembershipRole
  status         MembershipStatus @default(INVITED)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, status])
  @@map("memberships")
}

model AuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  action         String
  targetType     String        @map("target_type")
  targetId       String?       @map("target_id") @db.Uuid
  metadata       Json?
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Client {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String                   @map("organization_id") @db.Uuid
  assignedUserId         String?                  @map("assigned_user_id") @db.Uuid
  type                   ClientType               @default(PERSON)
  roles                  ClientRole[]             @default([])
  status                 ClientStatus             @default(NEW)
  temperature            ClientTemperature        @default(WARM)
  firstName              String?                  @map("first_name")
  lastName               String?                  @map("last_name")
  companyName            String?                  @map("company_name")
  displayName            String                   @map("display_name")
  legalId                String?                  @map("legal_id")
  email                  String?
  phone                  String?
  alternatePhone         String?                  @map("alternate_phone")
  whatsapp               String?
  preferredContactMethod ContactMethod?           @map("preferred_contact_method")
  country                String?
  city                   String?
  zone                   String?
  address                String?
  source                 String?
  interestType           ClientInterestType?      @map("interest_type")
  budgetMin              Int?                     @map("budget_min")
  budgetMax              Int?                     @map("budget_max")
  currency               String                   @default("USD")
  preferredZones         String[]                 @default([]) @map("preferred_zones")
  propertyTypes          String[]                 @default([]) @map("property_types")
  bedroomsMin            Int?                     @map("bedrooms_min")
  bathroomsMin           Int?                     @map("bathrooms_min")
  parkingMin             Int?                     @map("parking_min")
  areaMin                Int?                     @map("area_min")
  areaMax                Int?                     @map("area_max")
  timeline               ClientTimeline?
  financingStatus        FinancingStatus?         @map("financing_status")
  lastContactAt          DateTime?                @map("last_contact_at")
  nextFollowUpAt         DateTime?                @map("next_follow_up_at")
  notes                  String?
  tags                   String[]                 @default([])
  marketingConsent       Boolean                  @default(false) @map("marketing_consent")
  dataConsent            Boolean                  @default(false) @map("data_consent")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignedUser           User?                    @relation("AssignedClients", fields: [assignedUserId], references: [id], onDelete: SetNull)
  identityDocuments      ClientIdentityDocument[]
  ownedProperties         Property[]               @relation("PropertyOwnerClient")
  primaryBusinesses       Business[]               @relation("BusinessPrimaryClient")
  businessParticipants    BusinessParticipant[]    @relation("BusinessParticipantClients")
  documents               Document[]
  ownedMandates           Mandate[]                @relation("MandateOwnerClient")
  showings                Showing[]
  offers                  Offer[]
  payoutProfiles          PayoutProfile[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, nextFollowUpAt])
  @@index([assignedUserId])
  @@map("clients")
}

model ClientIdentityDocument {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                     @map("organization_id") @db.Uuid
  clientId        String                     @map("client_id") @db.Uuid
  type            ClientIdentityDocumentType
  documentNumber  String?                    @map("document_number")
  issuingCountry  String?                    @map("issuing_country")
  firstName       String?                    @map("first_name")
  lastName        String?                    @map("last_name")
  birthDate       DateTime?                  @map("birth_date") @db.Date
  expirationDate  DateTime?                  @map("expiration_date") @db.Date
  fileName        String                     @map("file_name")
  mimeType        String                     @map("mime_type")
  fileSize        Int                        @map("file_size")
  content         Bytes
  ocrText         String?                    @map("ocr_text")
  extractedData   Json?                      @map("extracted_data")
  createdByUserId String?                    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                   @default(now()) @map("created_at")
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client          Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdByUser   User?                      @relation("CreatedClientIdentityDocuments", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([organizationId, clientId])
  @@index([organizationId, type, documentNumber])
  @@index([createdByUserId])
  @@map("client_identity_documents")
}

model Property {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  assignedUserId    String?             @map("assigned_user_id") @db.Uuid
  ownerClientId     String?             @map("owner_client_id") @db.Uuid
  title             String
  internalCode      String?             @map("internal_code")
  type              String
  operations        PropertyOperation[] @default([])
  status            PropertyStatus      @default(DRAFT)
  country           String
  city              String
  zone              String
  address           String?
  buildingName      String?             @map("building_name")
  unitNumber        String?             @map("unit_number")
  bedrooms          Int?
  bathrooms         Int?
  parkingSpaces     Int?                @map("parking_spaces")
  builtArea         Int?                @map("built_area")
  lotArea           Int?                @map("lot_area")
  floor             Int?
  yearBuilt         Int?                @map("year_built")
  salePrice         Int?                @map("sale_price")
  rentPrice         Int?                @map("rent_price")
  currency          String              @default("USD")
  maintenanceFee    Int?                @map("maintenance_fee")
  rentalDeposit     Int?                @map("rental_deposit")
  availableFrom     DateTime?           @map("available_from") @db.Date
  source            String?
  publicDescription String?             @map("public_description")
  privateNotes      String?             @map("private_notes")
  listingConditions String?             @map("listing_conditions")
  amenities         String[]            @default([])
  tags              String[]            @default([])
  withdrawnAt       DateTime?           @map("withdrawn_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignedUser      User?               @relation("AssignedProperties", fields: [assignedUserId], references: [id], onDelete: SetNull)
  ownerClient       Client?             @relation("PropertyOwnerClient", fields: [ownerClientId], references: [id], onDelete: SetNull)
  businesses        Business[]
  documents         Document[]
  mandates          Mandate[]
  listings          Listing[]
  showings          Showing[]
  offers            Offer[]

  @@unique([organizationId, internalCode])
  @@index([organizationId, status])
  @@index([organizationId, zone])
  @@index([assignedUserId])
  @@index([ownerClientId])
  @@map("properties")
}

model RealEstateAgent {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  category       RealEstateAgentCategory
  firstName      String                  @map("first_name")
  lastName       String                  @map("last_name")
  displayName    String                  @map("display_name")
  companyName    String?                 @map("company_name")
  email          String?
  phone          String?
  whatsapp       String?
  licenseNumber  String?                 @map("license_number")
  notes          String?
  isActive       Boolean                 @default(true) @map("is_active")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  businessParticipants BusinessParticipant[]
  showings       Showing[]
  payoutProfiles PayoutProfile[]

  @@unique([organizationId, email])
  @@index([organizationId, category])
  @@index([organizationId, isActive])
  @@map("real_estate_agents")
}

model Business {
  id                        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String                @map("organization_id") @db.Uuid
  code                      String?
  title                     String?
  status                    BusinessStatus        @default(DRAFT)
  mode                      BusinessMode          @default(SIMPLE)
  operationType             BusinessOperationType @map("operation_type")
  propertyId                String?               @map("property_id") @db.Uuid
  primaryClientId           String?               @map("primary_client_id") @db.Uuid
  contractTypeId            String?               @map("contract_type_id") @db.Uuid
  currency                  String                @default("USD")
  basePriceCents            BigInt?               @map("base_price_cents")
  negotiatedPriceCents      BigInt?               @map("negotiated_price_cents")
  totalContractAmountCents  BigInt?               @map("total_contract_amount_cents")
  payableAmountCents        BigInt?               @map("payable_amount_cents")
  commissionBaseAmountCents BigInt?               @map("commission_base_amount_cents")
  expectedSignatureDate     DateTime?             @map("expected_signature_date") @db.Date
  expectedClosingDate       DateTime?             @map("expected_closing_date") @db.Date
  effectiveDate             DateTime?             @map("effective_date") @db.Date
  notes                     String?
  draftData                 Json?                 @map("draft_data")
  lastPreview               Json?                 @map("last_preview")
  idempotencyKey            String?               @map("idempotency_key")
  createdByUserId           String?               @map("created_by_user_id") @db.Uuid
  updatedByUserId           String?               @map("updated_by_user_id") @db.Uuid
  lockedAt                  DateTime?             @map("locked_at")
  lockedByUserId            String?               @map("locked_by_user_id") @db.Uuid
  version                   Int                   @default(1)
  committedAt               DateTime?             @map("committed_at")
  cancelledAt               DateTime?             @map("cancelled_at")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")
  organization              Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  property                  Property?             @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  primaryClient             Client?               @relation("BusinessPrimaryClient", fields: [primaryClientId], references: [id], onDelete: SetNull)
  contractType              ContractType?         @relation(fields: [contractTypeId], references: [id], onDelete: Restrict)
  createdByUser             User?                 @relation("CreatedBusinesses", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser             User?                 @relation("UpdatedBusinesses", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lockedByUser              User?                 @relation("LockedBusinesses", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  participants              BusinessParticipant[]
  contracts                 BusinessContract[]
  fees                      BusinessFee[]
  paymentPlans              PaymentPlan[]
  paymentScheduleLines      PaymentScheduleLine[]
  commissionPlans           CommissionPlan[]
  commissionAllocations     CommissionAllocation[]
  calculationSnapshots      CalculationSnapshot[]
  scheduledActions          ScheduledAction[]
  documents                 Document[]
  showings                  Showing[]
  offers                    Offer[]
  sourceDisbursements       Disbursement[]              @relation("SourceBusinessDisbursements")
  destinationCompensations  CompensationApplication[]   @relation("DestinationBusinessCompensations")

  @@unique([organizationId, code])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status])
  @@index([organizationId, operationType])
  @@index([propertyId])
  @@index([primaryClientId])
  @@index([contractTypeId])
  @@index([createdByUserId])
  @@map("businesses")
}

