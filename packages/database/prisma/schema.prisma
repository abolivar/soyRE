  propertyId               String        @map("property_id") @db.Uuid
  ownerClientId            String?       @map("owner_client_id") @db.Uuid
  assignedUserId           String?       @map("assigned_user_id") @db.Uuid
  type                     MandateType
  status                   MandateStatus @default(DRAFT)
  exclusive                Boolean       @default(false)
  authorizedPriceCents     BigInt?       @map("authorized_price_cents")
  currency                 String        @default("USD")
  commissionBps            Int?          @map("commission_bps")
  startsAt                 DateTime?     @map("starts_at") @db.Date
  endsAt                   DateTime?     @map("ends_at") @db.Date
  signedAt                 DateTime?     @map("signed_at") @db.Date
  notes                    String?
  metadata                 Json?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")
  organization             Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  property                 Property      @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  ownerClient              Client?       @relation("MandateOwnerClient", fields: [ownerClientId], references: [id], onDelete: SetNull)
  assignedUser             User?         @relation("AssignedMandates", fields: [assignedUserId], references: [id], onDelete: SetNull)
  listings                 Listing[]

  @@index([organizationId, status])
  @@index([propertyId, status])
  @@index([ownerClientId])
  @@index([assignedUserId])
  @@map("mandates")
}

model Listing {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  propertyId     String        @map("property_id") @db.Uuid
  mandateId      String?       @map("mandate_id") @db.Uuid
  status         ListingStatus @default(DRAFT)
  title          String
  publicCopy     String?       @map("public_copy")
  channels       String[]      @default([])
  readiness      Json?
  approvedAt     DateTime?     @map("approved_at")
  publishedAt    DateTime?     @map("published_at")
  pausedAt       DateTime?     @map("paused_at")
  archivedAt     DateTime?     @map("archived_at")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  mandate        Mandate?      @relation(fields: [mandateId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([propertyId, status])
  @@index([mandateId])
  @@map("listings")
}

model Showing {
