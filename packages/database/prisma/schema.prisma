  realEstateAgentId String?                @map("real_estate_agent_id") @db.Uuid
  status            ShowingStatus          @default(REQUESTED)
  scheduledFor      DateTime               @map("scheduled_for")
  completedAt       DateTime?              @map("completed_at")
  outcome           String?
  feedback          String?
