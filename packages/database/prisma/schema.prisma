generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum MembershipRole {
  OWNER
  ADMIN
  BROKER
  AGENT
  OPERATIONS
  FINANCE
  EXTERNAL_AGENT
  READONLY
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ClientType {
  PERSON
  COMPANY
}

enum ClientRole {
  BUYER
  SELLER
  LESSOR
  LESSEE
  INVESTOR
  LEAD
  REFERRER
  RELATED_CONTACT
}

enum ClientStatus {
  NEW
  ACTIVE
  NURTURING
  INACTIVE
  ARCHIVED
}

enum ClientTemperature {
  COLD
  WARM
  HOT
}

enum ContactMethod {
  EMAIL
  PHONE
  WHATSAPP
  SMS
  IN_PERSON
}

enum ClientInterestType {
  BUY
  RENT
  SELL
  LEASE
  INVEST
  MANAGE
  REFER
}

enum ClientTimeline {
  IMMEDIATE
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS
  EXPLORING
}

enum FinancingStatus {
  CASH
  PRE_APPROVED
  NEEDS_FINANCING
  UNKNOWN
}

enum ClientIdentityDocumentType {
  PASSPORT
  NATIONAL_ID
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  PUBLISHED
  RESERVED
  UNDER_CONTRACT
  CLOSED
  WITHDRAWN
  ARCHIVED
}

enum PropertyOperation {
  SALE
  RENT
}

enum RealEstateAgentCategory {
  BROKER
  EXTERNAL_BROKER
  REFERRER
}

model Organization {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                   @unique
  status                  OrganizationStatus       @default(ACTIVE)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  memberships             Membership[]
  auditLogs               AuditLog[]
  clients                 Client[]
  clientIdentityDocuments ClientIdentityDocument[]
  properties              Property[]
  realEstateAgents        RealEstateAgent[]

  @@map("organizations")
}

model User {
  id                             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                          String                   @unique
  firstName                      String                   @map("first_name")
  lastName                       String?                  @map("last_name")
  passwordHash                   String                   @map("password_hash")
  status                         UserStatus               @default(PENDING)
  emailVerifiedAt                DateTime?                @map("email_verified_at")
  lastLoginAt                    DateTime?                @map("last_login_at")
  createdAt                      DateTime                 @default(now()) @map("created_at")
  updatedAt                      DateTime                 @updatedAt @map("updated_at")
  memberships                    Membership[]
  auditLogs                      AuditLog[]               @relation("ActorAuditLogs")
  assignedClients                Client[]                 @relation("AssignedClients")
  assignedProperties             Property[]               @relation("AssignedProperties")
  createdClientIdentityDocuments ClientIdentityDocument[] @relation("CreatedClientIdentityDocuments")

  @@map("users")
}

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           MembershipRole
  status         MembershipStatus @default(INVITED)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, status])
  @@map("memberships")
}

model AuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  action         String
  targetType     String        @map("target_type")
  targetId       String?       @map("target_id") @db.Uuid
  metadata       Json?
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Client {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String                   @map("organization_id") @db.Uuid
  assignedUserId         String?                  @map("assigned_user_id") @db.Uuid
  type                   ClientType               @default(PERSON)
  roles                  ClientRole[]             @default([])
  status                 ClientStatus             @default(NEW)
  temperature            ClientTemperature        @default(WARM)
  firstName              String?                  @map("first_name")
  lastName               String?                  @map("last_name")
  companyName            String?                  @map("company_name")
  displayName            String                   @map("display_name")
  legalId                String?                  @map("legal_id")
  email                  String?
  phone                  String?
  alternatePhone         String?                  @map("alternate_phone")
  whatsapp               String?
  preferredContactMethod ContactMethod?           @map("preferred_contact_method")
  country                String?
  city                   String?
  zone                   String?
  address                String?
  source                 String?
  interestType           ClientInterestType?      @map("interest_type")
  budgetMin              Int?                     @map("budget_min")
  budgetMax              Int?                     @map("budget_max")
  currency               String                   @default("USD")
  preferredZones         String[]                 @default([]) @map("preferred_zones")
  propertyTypes          String[]                 @default([]) @map("property_types")
  bedroomsMin            Int?                     @map("bedrooms_min")
  bathroomsMin           Int?                     @map("bathrooms_min")
  parkingMin             Int?                     @map("parking_min")
  areaMin                Int?                     @map("area_min")
  areaMax                Int?                     @map("area_max")
  timeline               ClientTimeline?
  financingStatus        FinancingStatus?         @map("financing_status")
  lastContactAt          DateTime?                @map("last_contact_at")
  nextFollowUpAt         DateTime?                @map("next_follow_up_at")
  notes                  String?
  tags                   String[]                 @default([])
  marketingConsent       Boolean                  @default(false) @map("marketing_consent")
  dataConsent            Boolean                  @default(false) @map("data_consent")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignedUser           User?                    @relation("AssignedClients", fields: [assignedUserId], references: [id], onDelete: SetNull)
  identityDocuments      ClientIdentityDocument[]
  ownedProperties         Property[]               @relation("PropertyOwnerClient")

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, nextFollowUpAt])
  @@index([assignedUserId])
  @@map("clients")
}

model ClientIdentityDocument {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                     @map("organization_id") @db.Uuid
  clientId        String                     @map("client_id") @db.Uuid
  type            ClientIdentityDocumentType
  documentNumber  String?                    @map("document_number")
  issuingCountry  String?                    @map("issuing_country")
  firstName       String?                    @map("first_name")
  lastName        String?                    @map("last_name")
  birthDate       DateTime?                  @map("birth_date") @db.Date
  expirationDate  DateTime?                  @map("expiration_date") @db.Date
  fileName        String                     @map("file_name")
  mimeType        String                     @map("mime_type")
  fileSize        Int                        @map("file_size")
  content         Bytes
  ocrText         String?                    @map("ocr_text")
  extractedData   Json?                      @map("extracted_data")
  createdByUserId String?                    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                   @default(now()) @map("created_at")
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client          Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdByUser   User?                      @relation("CreatedClientIdentityDocuments", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([organizationId, clientId])
  @@index([organizationId, type, documentNumber])
  @@index([createdByUserId])
  @@map("client_identity_documents")
}

model Property {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  assignedUserId    String?             @map("assigned_user_id") @db.Uuid
  ownerClientId     String?             @map("owner_client_id") @db.Uuid
  title             String
  internalCode      String?             @map("internal_code")
  type              String
  operations        PropertyOperation[] @default([])
  status            PropertyStatus      @default(DRAFT)
  country           String
  city              String
  zone              String
  address           String?
  buildingName      String?             @map("building_name")
  unitNumber        String?             @map("unit_number")
  bedrooms          Int?
  bathrooms         Int?
  parkingSpaces     Int?                @map("parking_spaces")
  builtArea         Int?                @map("built_area")
  lotArea           Int?                @map("lot_area")
  floor             Int?
  yearBuilt         Int?                @map("year_built")
  salePrice         Int?                @map("sale_price")
  rentPrice         Int?                @map("rent_price")
  currency          String              @default("USD")
  maintenanceFee    Int?                @map("maintenance_fee")
  rentalDeposit     Int?                @map("rental_deposit")
  availableFrom     DateTime?           @map("available_from") @db.Date
  source            String?
  publicDescription String?             @map("public_description")
  privateNotes      String?             @map("private_notes")
  listingConditions String?             @map("listing_conditions")
  amenities         String[]            @default([])
  tags              String[]            @default([])
  withdrawnAt       DateTime?           @map("withdrawn_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignedUser      User?               @relation("AssignedProperties", fields: [assignedUserId], references: [id], onDelete: SetNull)
  ownerClient       Client?             @relation("PropertyOwnerClient", fields: [ownerClientId], references: [id], onDelete: SetNull)

  @@unique([organizationId, internalCode])
  @@index([organizationId, status])
  @@index([organizationId, zone])
  @@index([assignedUserId])
  @@index([ownerClientId])
  @@map("properties")
}

model RealEstateAgent {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  category       RealEstateAgentCategory
  firstName      String                  @map("first_name")
  lastName       String                  @map("last_name")
  displayName    String                  @map("display_name")
  companyName    String?                 @map("company_name")
  email          String?
  phone          String?
  whatsapp       String?
  licenseNumber  String?                 @map("license_number")
  notes          String?
  isActive       Boolean                 @default(true) @map("is_active")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, email])
  @@index([organizationId, category])
  @@index([organizationId, isActive])
  @@map("real_estate_agents")
}
