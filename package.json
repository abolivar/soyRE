{
  "name": "soyre",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "22.x",
    "pnpm": "10.33.2"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime.mjs",
    "runtime:check": "node scripts/check-runtime.mjs",
    "dev": "pnpm dev:check && turbo dev --env-mode=loose",
    "dev:check": "pnpm runtime:check && node scripts/check-dev-environment.mjs",
    "build": "pnpm runtime:check && turbo build",
    "build:web": "pnpm runtime:check && turbo build --filter=@soyre/web...",
    "vercel:build": "pnpm runtime:check && pnpm dlx vercel@56.4.0 build --prod --project soypms-alpha --yes",
    "lint": "pnpm runtime:check && pnpm check:design-system && turbo lint",
    "check:design-system": "node scripts/check-design-system.mjs",
    "typecheck": "pnpm runtime:check && turbo typecheck",
    "test": "pnpm runtime:check && node --test scripts/*.test.mjs && turbo test",
    "test:api-smoke": "pnpm --filter @soyre/api build && tsx --test tests/api-smoke.test.ts",
    "test:alpha": "pnpm --filter @soyre/api build && tsx --test tests/alpha/*.test.ts",
    "test:client-zero": "pnpm --filter @soyre/api build && tsx --test tests/alpha/api-alpha-smoke.test.ts",
    "test:mandates-beta": "pnpm --filter @soyre/api build && tsx --test tests/alpha/mandate-lifecycle-api.test.ts",
    "test:mandates-adversarial": "pnpm --filter @soyre/api build && tsc -p tests/tsconfig.mandates.json && tsx --test tests/alpha/mandate-adversarial-api.test.ts",
    "test:mandates-e2e": "pnpm --filter @soyre/api build && tsc -p tests/tsconfig.mandates.json && tsx --test tests/alpha/mandate-workspace-e2e.test.ts",
    "test:e2e": "pnpm --filter @soyre/web test:e2e",
    "playwright:install": "pnpm --filter @soyre/web exec playwright install chromium",
    "format": "prettier --write .",
    "db:generate": "pnpm runtime:check && pnpm --filter @soyre/database db:generate",
    "db:migrate": "pnpm db:migrate:deploy",
    "db:migrate:deploy": "pnpm --filter @soyre/database db:migrate:deploy",
    "db:studio": "pnpm --filter @soyre/database db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@soyre/database": "workspace:*",
    "@types/node": "^22.20.0",
    "corepack": "0.35.0",
    "eslint": "^10.6.0",
    "next": "16.2.6",
    "prettier": "^3.9.3",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
